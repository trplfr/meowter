{
  "name": "meowter",
  "private": true,
  "workspaces": [
    "web",
    "api",
    "shared"
  ],
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "concurrently \"yarn workspace api dev\" \"yarn workspace web dev\"",
    "dev:api": "yarn workspace api dev",
    "dev:web": "yarn workspace web dev",
    "build": "yarn workspaces foreach -A run build",
    "lint": "yarn workspaces foreach -A run lintобъ",
    "test": "yarn workspaces foreach -A run test",
    "test:api": "yarn workspace api test",
    "test:web": "yarn workspace web test",
    "lingui:extract": "yarn workspace web lingui extract",
    "db": "yarn workspace api drizzle-kit generate && yarn workspace api drizzle-kit migrate",
    "db:migrate": "yarn workspace api drizzle-kit migrate",
    "db:generate": "yarn workspace api drizzle-kit generate",
    "db:push": "yarn workspace api drizzle-kit push",
    "db:seed": "yarn workspace api seed",
    "db:view": "yarn workspace api drizzle-kit studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  }
}
